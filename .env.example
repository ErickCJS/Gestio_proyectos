APP_SECRET_KEY=cambia_esta_clave_larga_en_produccion

# Opcion 1: variables separadas para MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gestion_riesgo
DB_SSL_MODE=REQUIRED

# Opcion 2: una sola URL de conexion. Si usas esta, puede reemplazar las variables DB_*.
# DATABASE_URL=mysql://usuario:password@host:3306/gestion_riesgo

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
